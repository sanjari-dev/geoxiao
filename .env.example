# ClickHouse
CH_HOST=192.168.100.17
CH_PORT=8123
CH_DATABASE=geonera
CH_USER=admin
CH_PASSWORD=sans

# PostgreSQL
PG_HOST=192.168.100.17
PG_PORT=5432
PG_DATABASE=geonera
PG_USER=admin
PG_PASSWORD=sans
PG_DSN=postgresql+asyncpg://admin:sans@192.168.100.17:5432/geonera

# Optuna
OPTUNA_STORAGE=postgresql+psycopg://admin:sans@192.168.100.17:5432/geonera

# Ray
RAY_ADDRESS=local   # force local Ray instance for WSL laptop run

# Evolution
SYMBOL=AUDUSD
TIMEFRAME=H1
N_GENERATIONS=1
POP_SIZE=2

# Analytics
USE_GPU=true      # CUDA/CuPy verified in WSL

# Logging
LOG_FORMAT=console    # easier monitoring during local run
LOG_LEVEL=INFO

OPTUNA_N_TRIALS=3
