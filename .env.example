# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DATABASE=market_data
CH_USER=default
CH_PASSWORD=

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=geoxiao
PG_USER=geoxiao
PG_PASSWORD=secret
PG_DSN=postgresql+asyncpg://geoxiao:secret@localhost:5432/geoxiao
PG_DSN_SYNC=postgresql://geoxiao:secret@localhost:5432/geoxiao

# Optuna
OPTUNA_STORAGE=postgresql://geoxiao:secret@localhost:5432/geoxiao

# Ray
RAY_ADDRESS=auto   # 'auto' untuk local cluster

# Evolution
N_GENERATIONS=100
POP_SIZE=50

# Analytics
USE_GPU=false      # Set true jika CUDA available

# Logging
LOG_FORMAT=json    # 'json' untuk production, 'console' untuk dev
LOG_LEVEL=INFO

